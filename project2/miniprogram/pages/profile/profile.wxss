page {
  background: var(--page-bg);
}

.page-body {
  padding: 16px 20px 40px;
}

.user-card {
  background: #FFFFFF;
  border-radius: 24px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}

.avatar {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  border: 2px solid #FFFFFF;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.user-details {
  flex: 1;
}

.user-name {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.pro-badge {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 10px;
  background: linear-gradient(135deg, #E0A146 0%, #D45D4B 50%, #7A86B6 100%);
  color: #FFFFFF;
}

.user-id {
  font-size: 13px;
  color: var(--text-secondary);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding-top: 12px;
  border-top: 1px solid #F2F2F7;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
}

.stat-label {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 4px;
}

.stat-divider {
  width: 1px;
  background: #E5E5EA;
}

.pro-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-radius: 20px;
  background: linear-gradient(135deg, #1C1C1E 0%, #2C2C2E 100%);
  margin-bottom: 24px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}

.pro-banner-title {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4px;
}

.pro-banner-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.6);
}

.pro-banner-arrow {
  font-size: 24px;
  color: rgba(255,255,255,0.4);
}

.menu-group {
  margin-bottom: 24px;
}

.menu-group-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 12px;
  padding-left: 4px;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #F2F2F7;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.menu-icon {
  font-size: 18px;
}

.menu-label {
  font-size: 15px;
  color: var(--text-primary);
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 4px;
}

.menu-value {
  font-size: 13px;
  color: var(--text-secondary);
}

.menu-arrow {
  font-size: 16px;
  color: #C7C7CC;
}

.version-info {
  text-align: center;
  padding: 16px;
  font-size: 11px;
  color: #C7C7CC;
}
