page {
  background: var(--page-bg);
}

.page-body {
  padding: 0 20px 40px;
}

.tab-bar {
  display: flex;
  background: #FFFFFF;
  border-radius: 16px;
  padding: 4px;
  margin: 16px 0 20px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  border-radius: 12px;
  transition: all 0.2s;
}

.tab-item.active {
  background: #E0A146;
  color: #FFFFFF;
}

/* FAQ */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.faq-item {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.faq-q-text {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
  flex: 1;
  line-height: 1.5;
}

.faq-arrow {
  font-size: 18px;
  color: #C7C7CC;
  transition: transform 0.2s;
  margin-left: 8px;
}

.faq-arrow.rotated {
  transform: rotate(90deg);
}

.faq-answer {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid #F2F2F7;
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* Feedback Form */
.feedback-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.form-intro {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.7;
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.form-group {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.form-label {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 10px;
}

.required {
  color: #D45D4B;
}

.form-textarea {
  width: 100%;
  min-height: 140px;
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.6;
  padding: 12px;
  background: #F9F9F9;
  border-radius: 12px;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 11px;
  color: #C7C7CC;
  margin-top: 6px;
}

.form-input {
  width: 100%;
  height: 44px;
  font-size: 14px;
  color: var(--text-primary);
  padding: 0 12px;
  background: #F9F9F9;
  border-radius: 12px;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 48px;
  background: #E0A146;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 14px;
  border: none;
  line-height: 48px;
  text-align: center;
}

.submit-btn.disabled {
  background: #C7C7CC;
  color: #FFFFFF;
}

.form-footer {
  text-align: center;
  font-size: 12px;
  color: #C7C7CC;
  line-height: 1.6;
}

.bottom-space {
  height: 40px;
}
