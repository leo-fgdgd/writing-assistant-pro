page {
  background: var(--page-bg);
}

.page-body {
  padding: 16px 20px;
  height: 100vh;
}

.mode-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}

.mode-card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 14px;
  border: 2px solid transparent;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.mode-active {
  border-color: #E0A146;
  background: #FEF3C7;
}

.mode-icon {
  width: 32px;
  height: 32px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  margin-bottom: 8px;
}

.mode-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.mode-desc {
  font-size: 12px;
  color: var(--text-secondary);
}

.input-section {
  margin-bottom: 16px;
}

.input-label {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.text-input {
  width: 100%;
  background: #FFFFFF;
  border-radius: 16px;
  padding: 12px 16px;
  font-size: 15px;
  line-height: 1.75;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  box-sizing: border-box;
  min-height: 120px;
}

.examples {
  margin-bottom: 16px;
}

.example-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.example-chip {
  font-size: 12px;
  padding: 6px 12px;
  border-radius: 20px;
  background: #FFFFFF;
  color: var(--text-secondary);
  border: 1px solid #E5E5EA;
  max-width: 180px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.polish-btn {
  width: 100%;
  height: 48px;
  border-radius: 24px;
  background: #1C1C1E;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 20px;
}

.btn-disabled {
  opacity: 0.6;
}

.result-section {
  margin-top: 8px;
  margin-bottom: 40px;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.copy-btn {
  font-size: 12px;
  color: var(--text-secondary);
  padding: 4px 12px;
  border-radius: 20px;
  background: rgba(255,255,255,0.8);
  border: 1px solid #E5E5EA;
}

.result-card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  border-left: 4px solid #E0A146;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.result-text {
  font-size: 15px;
  line-height: 1.75;
  color: var(--text-primary);
  white-space: pre-wrap;
}
