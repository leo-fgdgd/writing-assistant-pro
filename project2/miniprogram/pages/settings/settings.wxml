<!--settings.wxml-->
<scroll-view scroll-y class="page-body">

  <!-- Display Settings -->
  <view class="section">
    <view class="section-title">显示设置</view>
    <view class="card">
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-label">字体大小</text>
          <text class="setting-desc">调整创作区的文字大小</text>
        </view>
        <view class="setting-right">
          <slider
            class="font-slider"
            min="0"
            max="2"
            step="1"
            value="{{fontSizeIndex}}"
            show-value="{{false}}"
            activeColor="#E0A146"
            backgroundColor="#E5E5EA"
            block-size="20"
            bindchange="onFontSizeChange"
          />
          <text class="font-label">{{settings.fontSize}}px</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Functional Settings -->
  <view class="section">
    <view class="section-title">功能设置</view>
    <view class="card">
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-label">自动保存</text>
          <text class="setting-desc">创作内容自动保存到历史记录</text>
        </view>
        <view class="setting-right">
          <switch
            checked="{{settings.autoSave}}"
            color="#E0A146"
            bindchange="onToggleAutoSave"
          />
        </view>
      </view>
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-label">音效反馈</text>
          <text class="setting-desc">操作时播放提示音</text>
        </view>
        <view class="setting-right">
          <switch
            checked="{{settings.soundEffect}}"
            color="#E0A146"
            bindchange="onToggleSound"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- Data Management -->
  <view class="section">
    <view class="section-title">数据管理</view>
    <view class="card">
      <view class="setting-item" bindtap="onClearCache">
        <view class="setting-left">
          <text class="setting-label">清除缓存</text>
          <text class="setting-desc">当前缓存 {{settings.cacheSize}}</text>
        </view>
        <view class="setting-right">
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- About -->
  <view class="section">
    <view class="section-title">关于</view>
    <view class="card">
      <view class="setting-item" bindtap="onAbout">
        <view class="setting-left">
          <text class="setting-label">关于语灵 AI</text>
          <text class="setting-desc">版本信息与团队介绍</text>
        </view>
        <view class="setting-right">
          <text class="version-tag">v2.1.0</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</scroll-view>

<!-- Clear Cache Confirm Dialog -->
<view class="modal-mask" wx:if="{{showClearConfirm}}" bindtap="onCancelClear"></view>
<view class="modal-dialog" wx:if="{{showClearConfirm}}">
  <view class="modal-title">确认清除缓存</view>
  <view class="modal-content">将清除所有本地临时数据，但保留登录状态和个人设置。</view>
  <view class="modal-actions">
    <button class="modal-btn cancel" bindtap="onCancelClear">取消</button>
    <button class="modal-btn confirm" bindtap="onConfirmClear">确认清除</button>
  </view>
</view>
