/**
 * 设置页 — 个性化配置
 * 分组列表 × 清晰开关 × 优雅弹窗
 */

page {
  background: var(--color-bg);
}

.page-body {
  padding: var(--space-md) var(--space-xl) var(--space-2xl);
}

/* ===== 分组 ===== */
.section {
  margin-bottom: var(--space-xl);
}

.section-title {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-text-muted);
  margin-bottom: var(--space-sm);
  padding-left: 8rpx;
  letter-spacing: 2rpx;
}

.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  border-bottom: 1rpx solid var(--color-border);
  min-height: 88rpx;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  flex: 1;
  margin-right: var(--space-md);
}

.setting-label {
  font-size: var(--text-base);
  color: var(--color-text);
  font-weight: 500;
  display: block;
}

.setting-desc {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: 2rpx;
  display: block;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-shrink: 0;
}

.font-slider {
  width: 160rpx;
}

.font-label {
  font-size: var(--text-sm);
  color: var(--color-text-sub);
  min-width: 40rpx;
  text-align: right;
}

.arrow {
  font-size: var(--text-lg);
  color: #D0CCC5;
}

.version-tag {
  font-size: var(--text-xs);
  color: var(--color-text-sub);
  background: #F9F7F2;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.bottom-space {
  height: var(--space-2xl);
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

.modal-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  z-index: 1001;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  animation: fadeInUp 0.25s ease;
}

.modal-title {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  margin-bottom: var(--space-sm);
}

.modal-content {
  font-size: var(--text-base);
  color: var(--color-text-sub);
  text-align: center;
  line-height: 1.6;
  margin-bottom: var(--space-lg);
}

.modal-actions {
  display: flex;
  gap: var(--space-md);
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-base);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #F9F7F2;
  color: var(--color-text);
}

.modal-btn.confirm {
  background: var(--color-dark);
  color: #FFFFFF;
}

.modal-btn:active {
  opacity: 0.85;
}
