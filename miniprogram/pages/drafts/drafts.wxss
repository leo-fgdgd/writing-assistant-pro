page { background: var(--color-bg); }

.page-body {
  padding: var(--space-lg) var(--space-xl);
  box-sizing: border-box;
  min-height: 100vh;
}

/* ===== 列表 ===== */
.draft-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.draft-item {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid var(--color-brand);
  transition: transform 0.15s;
}

.draft-item:active { transform: scale(0.98); }

.draft-left {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  min-width: 0;
}

.draft-type {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.draft-info {
  flex: 1;
  min-width: 0;
}

.draft-title {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.draft-preview {
  font-size: var(--text-xs);
  color: var(--color-text-sub);
  margin-top: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.draft-time {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.draft-delete {
  font-size: 36rpx;
  flex-shrink: 0;
  padding: 8rpx;
  opacity: 0.5;
}

.draft-delete:active { opacity: 1; }

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon { font-size: 80rpx; opacity: 0.5; margin-bottom: var(--space-lg); }
.empty-title { font-size: var(--text-lg); font-weight: 600; color: var(--color-text); margin-bottom: var(--space-sm); }
.empty-desc { font-size: var(--text-sm); color: var(--color-text-muted); text-align: center; padding: 0 var(--space-xl); }
