page { background: var(--color-bg); }

.page-body {
  padding: var(--space-lg) var(--space-xl);
  box-sizing: border-box;
  min-height: 100vh;
}

/* ===== 列表 ===== */
.fav-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.fav-item {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid #E0A146;
  transition: transform 0.15s;
}

.fav-item:active { transform: scale(0.98); }

.fav-left {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  min-width: 0;
}

.fav-type {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.fav-info {
  flex: 1;
  min-width: 0;
}

.fav-title {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-preview {
  font-size: var(--text-xs);
  color: var(--color-text-sub);
  margin-top: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.fav-time {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.fav-delete {
  font-size: 36rpx;
  flex-shrink: 0;
  padding: 8rpx;
  opacity: 0.5;
}

.fav-delete:active { opacity: 1; }

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon { font-size: 80rpx; opacity: 0.5; margin-bottom: var(--space-lg); }
.empty-title { font-size: var(--text-lg); font-weight: 600; color: var(--color-text); margin-bottom: var(--space-sm); }
.empty-desc { font-size: var(--text-sm); color: var(--color-text-muted); text-align: center; padding: 0 var(--space-xl); }

/* ===== 详情弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

.detail-modal {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  top: 120rpx;
  background: var(--color-bg);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg) var(--space-xl);
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.detail-title {
  font-size: var(--text-lg);
  font-weight: 700;
}

.detail-close {
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
}

.close-icon {
  width: 32rpx; height: 32rpx; opacity: 0.5;
}

.detail-body {
  flex: 1;
  padding: var(--space-lg) var(--space-xl);
}

.detail-section {
  margin-bottom: var(--space-lg);
}

.detail-label {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text-sub);
  margin-bottom: var(--space-sm);
}

.detail-card {
  border-radius: var(--radius-md);
  padding: var(--space-md) var(--space-lg);
  border-left: 4rpx solid var(--color-brand);
}

.user-card-bg { background: #F5F3EC; }
.ai-card-bg { background: var(--color-surface); border-color: #5B8C85; }

.detail-text {
  font-size: var(--text-sm);
  line-height: 1.7;
  color: var(--color-text);
  white-space: pre-wrap;
}

.detail-time {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  text-align: center;
  padding: var(--space-md);
}

.detail-footer {
  display: flex;
  gap: var(--space-md);
  padding: var(--space-md) var(--space-xl);
  padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom, 0));
  border-top: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: var(--text-base);
  font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  border: none;
}

.footer-btn.copy {
  background: var(--color-dark);
  color: #FFFFFF;
}

.footer-btn.unfav {
  background: #F1EFE9;
  color: var(--color-text-sub);
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
