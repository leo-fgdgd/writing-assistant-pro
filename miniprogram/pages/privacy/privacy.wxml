<!--privacy.wxml-->
<scroll-view scroll-y class="page-body">
  <!-- Tab Bar -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'privacy' ? 'active' : ''}}"
      data-tab="privacy"
      bindtap="switchTab"
    >
      <text>隐私政策</text>
    </view>
    <view
      class="tab-item {{activeTab === 'terms' ? 'active' : ''}}"
      data-tab="terms"
      bindtap="switchTab"
    >
      <text>服务条款</text>
    </view>
  </view>

  <!-- Privacy Policy Content -->
  <view class="content" wx:if="{{activeTab === 'privacy'}}">
    <view class="update-date">最后更新：2024年6月</view>
    <view class="intro">
      语灵 AI（以下简称"我们"）高度重视您的隐私保护。本隐私政策详细说明了我们如何收集、使用、存储和保护您的个人信息。使用本小程序即表示您同意本隐私政策的全部条款。
    </view>
    <view class="section" wx:for="{{privacySections}}" wx:key="title">
      <view class="section-title">{{item.title}}</view>
      <view class="section-content">{{item.content}}</view>
    </view>
  </view>

  <!-- Terms of Service Content -->
  <view class="content" wx:if="{{activeTab === 'terms'}}">
    <view class="update-date">最后更新：2024年6月</view>
    <view class="intro">
      欢迎使用语灵 AI。在使用本小程序前，请仔细阅读以下服务条款。使用本服务即表示您同意遵守本协议的全部内容。
    </view>
    <view class="section" wx:for="{{termsSections}}" wx:key="title">
      <view class="section-title">{{item.title}}</view>
      <view class="section-content">{{item.content}}</view>
    </view>
  </view>

  <view class="bottom-space"></view>
</scroll-view>
