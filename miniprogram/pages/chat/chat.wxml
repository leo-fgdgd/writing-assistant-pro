<!--chat.wxml-->
<scroll-view scroll-y class="chat-body" scroll-into-view="{{scrollToId}}">
  <!-- Empty State -->
  <view class="empty-state" wx:if="{{messages.length === 0 && !isTyping}}">
    <view class="empty-icon">✨</view>
    <view class="empty-title">语灵 AI 助手</view>
    <view class="empty-desc">告诉我你想写什么，我来帮你创作</view>
    <view class="quick-prompts">
      <view class="quick-prompt" wx:for="{{quickPrompts}}" wx:key="text" bindtap="onTapQuickPrompt" data-text="{{item.text}}">
        {{item.icon}} {{item.text}}
      </view>
    </view>
  </view>

  <!-- Messages -->
  <block wx:for="{{messages}}" wx:key="id">
    <view class="msg-row {{item.role === 'user' ? 'msg-right' : 'msg-left'}}">
      <view class="msg-avatar" wx:if="{{item.role === 'assistant'}}">✨</view>
      <view class="msg-bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}}">
        <text class="msg-text">{{item.content}}</text>
        <view class="msg-actions" wx:if="{{item.role === 'assistant'}}">
          <view class="msg-action" bindtap="onCopy" data-content="{{item.content}}">📋 复制</view>
          <view class="msg-action" bindtap="onFavorite" data-index="{{index}}">⭐ 收藏</view>
          <view class="msg-action" bindtap="onRegenerate">🔄 重新生成</view>
        </view>
      </view>
    </view>
  </block>

  <!-- Typing Indicator -->
  <view class="msg-row msg-left" wx:if="{{isTyping}}">
    <view class="msg-avatar">✨</view>
    <view class="msg-bubble bubble-ai typing-bubble">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
  </view>

  <view id="msg-end"></view>
</scroll-view>

<!-- Input Area -->
<view class="input-area" style="padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom, 0) + {{keyboardHeight}}px);">
  <!-- Caveman Toggle — 四级强度逐级递进 -->
  <view class="caveman-bar caveman-{{caveman || 'std'}}" bindtap="onToggleCaveman">
    <text class="caveman-dot">{{caveman === '' ? '📝' : caveman === 'lite' ? '🌱' : caveman === 'full' ? '⚡' : '💎'}}</text>
    <view class="caveman-info">
      <text class="caveman-label">
        <block wx:if="{{caveman === ''}}">标准输出</block>
        <block wx:elif="{{caveman === 'lite'}}">精简模式</block>
        <block wx:elif="{{caveman === 'full'}}">压缩模式</block>
        <block wx:else>极限压缩</block>
      </text>
      <text class="caveman-hint">
        <block wx:if="{{caveman === ''}}">点击可切换省 token 模式 →</block>
        <block wx:elif="{{caveman === 'lite'}}">省 ~40% token · 保留完整句结构</block>
        <block wx:elif="{{caveman === 'full'}}">省 ~70% token · 去虚词 短句优先</block>
        <block wx:else>省 ~85% token · 极限信息密度</block>
      </text>
    </view>
    <view class="caveman-indicator">
      <view class="caveman-step s1 active"></view>
      <view class="caveman-step s2 {{caveman === 'lite' || caveman === 'full' || caveman === 'ultra' ? 'active' : ''}}"></view>
      <view class="caveman-step s3 {{caveman === 'full' || caveman === 'ultra' ? 'active' : ''}}"></view>
      <view class="caveman-step s4 {{caveman === 'ultra' ? 'active' : ''}}"></view>
    </view>
  </view>

  <view class="input-row">
    <view class="draft-btn" wx:if="{{inputValue}}" bindtap="onSaveDraft">
      <text>📝</text>
    </view>
    <textarea
      class="chat-input"
      value="{{inputValue}}"
      placeholder="输入你的写作需求..."
      bindinput="onInput"
      bindconfirm="onSend"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      auto-height
      cursor-spacing="{{80}}"
      adjust-position="{{true}}"
      maxlength="-1"
    />
    <view class="send-btn {{inputValue ? 'send-active' : ''}}" bindtap="onSend">
      <text class="send-icon">↑</text>
    </view>
  </view>
</view>
