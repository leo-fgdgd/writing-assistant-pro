/**
 * 历史记录页 — 创作档案馆
 * 搜索筛选 × 时间线列表 × 清晰信息层级
 */

page {
  background: var(--color-bg);
}

.page-body {
  padding: var(--space-lg) var(--space-xl);
  box-sizing: border-box;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  background: var(--color-surface);
  border-radius: var(--radius-full);
  padding: 0 var(--space-lg);
  height: 80rpx;
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.search-icon {
  font-size: var(--text-lg);
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: var(--text-base);
  color: var(--color-text);
}

/* ===== 筛选标签 ===== */
.filter-tabs {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.filter-tab {
  padding: var(--space-xs) var(--space-lg);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 500;
  background: var(--color-surface);
  color: var(--color-text-sub);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid transparent;
  transition: all 0.2s;
}

.tab-active {
  background: var(--color-dark);
  color: #FFFFFF;
  border-color: var(--color-dark);
}

/* ===== 列表 ===== */
.history-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.history-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid transparent;
  transition: all 0.15s;
}

.history-item:active {
  background: #FAF8F4;
}

/* 按类型着色左边框 */
.history-item[data-type="chat"] {
  border-left-color: var(--color-brand);
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: 4rpx;
}

.item-title {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.item-type {
  font-size: var(--text-xs);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
  background: var(--color-brand-bg);
  color: var(--color-brand);
  flex-shrink: 0;
}

.item-preview {
  font-size: var(--text-sm);
  color: var(--color-text-sub);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--space-xs);
}

.item-meta {
  display: flex;
  gap: var(--space-md);
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}

.item-delete {
  padding: 8rpx;
  font-size: 32rpx;
  flex-shrink: 0;
  opacity: 0.5;
  transition: opacity 0.15s;
}

.item-delete:active {
  opacity: 1;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx var(--space-xl);
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: var(--space-md);
  opacity: 0.6;
}

.empty-text {
  font-size: var(--text-base);
  color: var(--color-text-muted);
}
